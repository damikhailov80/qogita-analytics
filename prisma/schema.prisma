// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                          Int      @id @default(autoincrement())
  gtin                        String   @unique @db.VarChar(14)
  name                        String   @db.Text
  category                    String?  @db.VarChar(255)
  brand                       String?  @db.VarChar(255)
  lowestPriceIncShipping      Decimal? @map("lowest_price_inc_shipping") @db.Decimal(10, 2)
  unit                        String?  @db.VarChar(50)
  lowestPricedOfferInventory  Int?     @map("lowest_priced_offer_inventory")
  isPreOrder                  Boolean  @default(false) @map("is_pre_order")
  estimatedDeliveryTimeWeeks  Int?     @map("estimated_delivery_time_weeks")
  numberOfOffers              Int?     @map("number_of_offers")
  totalInventoryAllOffers     Int?     @map("total_inventory_all_offers")
  productUrl                  String?  @map("product_url") @db.Text
  imageUrl                    String?  @map("image_url") @db.Text
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model Update {
  id        Int      @id @default(autoincrement())
  name      String   @db.Text
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("updates")
}
