// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                          Int      @id @default(autoincrement())
  gtin                        String   @unique @db.VarChar(14)
  name                        String   @db.Text
  category                    String?  @db.VarChar(255)
  brand                       String?  @db.VarChar(255)
  lowestPrice                 Decimal? @map("lowest_price") @db.Decimal(10, 2)
  unit                        String?  @db.VarChar(50)
  lowestPricedOfferInventory  Int?     @map("lowest_priced_offer_inventory")
  isPreOrder                  Boolean  @default(false) @map("is_pre_order")
  estimatedDeliveryTimeWeeks  Int?     @map("estimated_delivery_time_weeks")
  numberOfOffers              Int?     @map("number_of_offers")
  totalInventoryAllOffers     Int?     @map("total_inventory_all_offers")
  productUrl                  String?  @map("product_url") @db.Text
  imageUrl                    String?  @map("image_url") @db.Text

  offers                      Offer[]

  @@map("products")
}

model ProductAllegro {
  id            Int     @id @default(autoincrement())
  gtin          String  @unique @db.VarChar(14)
  salesQuantity Int     @map("sales_quantity")
  price         Decimal @db.Decimal(10, 2)

  @@map("products_allegro")
}

model WorkerLog {
  id          Int      @id @default(autoincrement())
  workerType  String   @map("worker_type") @db.VarChar(50) // 'allegro-upload' или 'qogita-update'
  jobId       String   @map("job_id") @db.VarChar(100)
  status      String   @db.VarChar(50) // 'completed', 'failed'
  logs        String[] @db.Text
  result      Json?    @db.JsonB
  error       String?  @db.Text
  startedAt   DateTime @map("started_at")
  completedAt DateTime @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workerType, createdAt])
  @@map("worker_logs")
}

model Seller {
  id              Int      @id @default(autoincrement())
  code            String   @unique @db.VarChar(50)
  minOrderValue   Decimal  @map("min_order_value") @db.Decimal(10, 2)
  currency        String   @default("EUR") @db.VarChar(3)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  offers          Offer[]

  @@map("sellers")
}

model Offer {
  id              Int      @id @default(autoincrement())
  gtin            String   @db.VarChar(14)
  sellerCode      String   @map("seller_code") @db.VarChar(50)
  price           Decimal  @db.Decimal(10, 2)
  priceCurrency   String   @map("price_currency") @db.VarChar(3)
  inventory       Int
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  product         Product  @relation(fields: [gtin], references: [gtin])
  seller          Seller   @relation(fields: [sellerCode], references: [code])

  @@unique([gtin, sellerCode])
  @@index([gtin])
  @@index([sellerCode])
  @@map("offers")
}
