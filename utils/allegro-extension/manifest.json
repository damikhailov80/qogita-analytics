{
    "manifest_version": 3,
    "name": "Allegro Price Extractor",
    "version": "1.0.0",
    "description": "Extracts prices from Allegro listings",
    "permissions": [
        "activeTab",
        "scripting",
        "clipboardWrite",
        "tabs"
    ],
    "host_permissions": [
        "https://allegro.pl/*",
        "https://*.allegro.pl/*",
        "http://localhost:3000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Allegro Price Extractor"
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost:3000/products/allegro*",
                "http://localhost:3000/sellers/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
}